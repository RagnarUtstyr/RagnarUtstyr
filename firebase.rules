rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner() { return signedIn() && resource.data.ownerId == request.auth.uid; }
    function isOwnerOnCreate() { return signedIn() && request.resource.data.ownerId == request.auth.uid; }

    match /equipment/{docId} {
      allow create: if isOwnerOnCreate();
      allow read, delete: if isOwner();
      allow update: if isOwner() && request.resource.data.ownerId == request.auth.uid;
    }

    match /rentals/{docId} {
      allow create: if isOwnerOnCreate();
      allow read, delete: if isOwner();
      allow update: if isOwner() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
